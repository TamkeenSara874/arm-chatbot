# Application
APP_ENV=development
DEBUG=true
# Bearer token required on all non-health endpoints
API_KEY=change-me-local-dev-key
LOG_LEVEL=INFO
# Comma-separated list; parsed into a list in Settings
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database (PostgreSQL)
# WARNING: change credentials before any non-local deployment
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/armchatbot

# Vector Database (Qdrant)
# Two collections: review_chunks + correction_embeddings
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_REVIEWS=review_chunks
QDRANT_COLLECTION_CORRECTIONS=correction_embeddings
QDRANT_COLLECTION_SESSION_MEMORY=session_memory

# Cache (Redis)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=86400

# LLM Providers
# Groq: free tier used for query decomposition (fast, rate-limited); falls back to OpenAI on 429
# OpenAI: paid, used for generation and embeddings
GROQ_API_KEY=
# Optional: additional free-tier Groq keys, comma-separated (e.g. "key2,key3,key4").
# Each key has its own daily quota; decomposition rotates across all of them
# (GROQ_API_KEY + these) before ever falling back to paid OpenAI.
GROQ_API_KEYS=
OPENAI_API_KEY=

# Model names (swap here, no code changes needed)
# Allowed OpenAI models: gpt-4o-mini, gpt-4.1-mini, gpt-4.1, text-embedding-3-large
OPENAI_SIMPLE_MODEL=gpt-4o-mini
OPENAI_COMPLEX_MODEL=gpt-4.1
OPENAI_EMBED_MODEL=text-embedding-3-large
GROQ_DECOMP_MODEL=llama-3.3-70b-versatile
# Cross-encoder reranker runs locally (no API cost); model is downloaded on first use.
# ms-marco-MiniLM-L6-v2 (~22M params) chosen over bge-reranker-base (~278M params) --
# live measurement showed bge-reranker-base taking 13-22s of CPU inference for just
# 24-30 candidates (the dominant cost in end-to-end latency by a wide margin).
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
# ONNX int8 dynamic quantization of the same reranker model -- only pays off
# together with RERANKER_BATCH_SIZE below (keeps candidate batches
# length-homogeneous). Verified live: rerank_ms 2.1-2.9s -> 0.8-1.0s combined
# with the batch-size fix; LLM-judge eval harness showed identical failures
# with this on vs off (all pre-existing, none reranker-caused). Explicit
# rollback via env var alone either way, no code deploy needed.
RERANKER_ONNX_QUANTIZED=true
# avx2 is safe on virtually all x86_64 CPUs from the last ~12 years. Use avx512_vnni
# only on recent server-class Intel CPUs, or arm64 for Graviton/Apple Silicon.
RERANKER_ONNX_QUANTIZATION_CONFIG=avx2
# CrossEncoder.predict() sorts candidates by length internally, but only within
# a batch -- with the default batch_size=32 and top_k always <=20, everything
# lands in one batch, so a single long review pads every candidate to its length.
# Live-measured: batch_size=8 cuts rerank_ms 2.5-4x on mixed-length candidates,
# no change to scores or rank order.
RERANKER_BATCH_SIZE=8

# Embeddings
EMBEDDING_DIM=3072

# Voice mode (dictation). Groq's free tier (2,000 requests/day as of writing)
# comfortably covers real usage -- same provider/key already used above.
STT_PROVIDER=groq
GROQ_STT_MODEL=whisper-large-v3-turbo
VOICE_MAX_UPLOAD_MB=10

# Rate Limiting (per API key, not per IP)
RATE_LIMIT_CHAT=10/minute
RATE_LIMIT_INGEST=5/minute
# Single-review live ingestion (POST /ingest/review) is lightweight and
# high-frequency compared to the batch file upload above.
RATE_LIMIT_INGEST_REVIEW=60/minute
RATE_LIMIT_CORRECT=20/minute
RATE_LIMIT_READ=60/minute
RATE_LIMIT_VOICE=20/minute

# Session — semantic retrieval design
SESSION_TTL_DAYS=30
SESSION_PURGE_INTERVAL_HOURS=6      # how often expired sessions are swept from Postgres + Qdrant
SESSION_RECENT_MESSAGES=5           # last N messages always included verbatim
SESSION_RELEVANT_K=3                # past turns retrieved by semantic ANN similarity to current query
SESSION_SUMMARY_TRIGGER=20          # rolling LLM summary first written at this message count
SESSION_SUMMARY_REFRESH_EVERY=20    # and refreshed every N messages beyond what it already covers
SESSION_CONTEXT_TOKEN_BUDGET=6000   # hard token cap for the full context block

# Ingestion
CHUNK_SIZE_TOKENS=256
CHUNK_OVERLAP_TOKENS=32
INGEST_BATCH_SIZE=100
INGEST_MAX_FILE_SIZE_MB=10
# Reviews per entity-extraction LLM call (batching reduces API calls by 10x)
ENTITY_EXTRACTION_BATCH_SIZE=10

# Evidence ranking weights (must sum to 1.0)
RANKING_WEIGHT_RRF=0.5
RANKING_WEIGHT_RECENCY=0.3
RANKING_WEIGHT_RATING=0.2

# Correction retrieval
CORRECTION_SIM_THRESHOLD=0.85

# Evidence quality
DATA_STALENESS_DAYS=365

# JWT — restaurant-scoped tokens; set a strong random secret (min 32 chars) in production
JWT_SECRET=change-me-jwt-secret-32-chars-min
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# HuggingFace — set to avoid unauthenticated rate limits when the reranker downloads at startup
HF_TOKEN=

# Observability
SENTRY_DSN=

# Grafana — only used with `docker compose --profile monitoring up`
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-local-dev-password
